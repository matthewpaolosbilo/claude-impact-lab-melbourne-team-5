  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "history": {
            "items": {
              "$ref": "#/components/schemas/HistoryMessage"
            },
            "type": "array",
            "title": "History"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "message"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "response": {
            "type": "string",
            "title": "Response"
          },
          "suggested_event_ids": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Suggested Event Ids"
          },
          "onboarding_complete": {
            "type": "boolean",
            "title": "Onboarding Complete",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "response",
          "suggested_event_ids"
        ],
        "title": "ChatResponse"
      },
      "EventCreate": {
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "title": "Title"
          },
          "description": {
            "type": "string",
            "title": "Description",
            "default": ""
          },
          "event_type": {
            "type": "string",
            "minLength": 1,
            "title": "Event Type"
          },
          "location_id": {
            "type": "integer",
            "title": "Location Id"
          },
          "start_time": {
            "type": "string",
            "format": "date-time",
            "title": "Start Time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time",
            "title": "End Time"
          },
          "max_attendees": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Attendees"
          }
        },
        "type": "object",
        "required": [
          "title",
          "event_type",
          "location_id",
          "start_time",
          "end_time"
        ],
        "title": "EventCreate"
      },
      "EventRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "event_type": {
            "type": "string",
            "title": "Event Type"
          },
          "start_time": {
            "type": "string",
            "format": "date-time",
            "title": "Start Time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time",
            "title": "End Time"
          },
          "host": {
            "$ref": "#/components/schemas/HostSummary"
          },
          "location": {
            "$ref": "#/components/schemas/LocationSummary"
          },
          "attendee_count": {
            "type": "integer",
            "title": "Attendee Count"
          },
          "max_attendees": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Attendees"
          },
          "user_rsvp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Rsvp"
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "event_type",
          "start_time",
          "end_time",
          "host",
          "location",
          "attendee_count"
        ],
        "title": "EventRead"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HistoryMessage": {
        "properties": {
          "role": {
            "type": "string",
            "pattern": "^(user|assistant)$",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "HistoryMessage"
      },
      "HostSummary": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "title": "HostSummary"
      },
      "LocationCreate": {
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "title": "Name"
          },
          "type": {
            "type": "string",
            "minLength": 1,
            "title": "Type"
          },
          "latitude": {
            "type": "number",
            "maximum": 90.0,
            "minimum": -90.0,
            "title": "Latitude"
          },
          "longitude": {
            "type": "number",
